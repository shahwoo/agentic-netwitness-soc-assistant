# ─────────────────────────────────────────────────────────────────────
# Streamlit Community Cloud secrets TEMPLATE
# ─────────────────────────────────────────────────────────────────────
# Do NOT put real values in a committed file. Instead, in the Streamlit
# Cloud dashboard:  your app  →  Settings  →  Secrets  →  paste the block
# below (with real values).  app.py copies these into os.environ at boot,
# so every existing os.environ.get(...) keeps working with no code change.
#
# (For LOCAL testing of the cloud path you may copy this to
#  .streamlit/secrets.toml and fill it in — that file is gitignored.)

# ── LLM provider (required for the 3 agents to run) ──────────────────
CISCO_LLM_URL   = "https://your-llm-endpoint/v1"
CISCO_LLM_KEY   = "sk-xxxxxxxxxxxxxxxxxxxx"
CISCO_LLM_MODEL = "deepseek-chat"

# ── NetWitness (leave blank in the cloud) ────────────────────────────
# NetWitness is on-prem / VPN-only and unreachable from Streamlit Cloud.
# Leave these unset so the app stays in offline/demo mode, serving the
# stored incidents bundled in soc_db/ and chroma_db/.
# NW_HOST     = ""
# NW_USERNAME = ""
# NW_PASSWORD = ""
