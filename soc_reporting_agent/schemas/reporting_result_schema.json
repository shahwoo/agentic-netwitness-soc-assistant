    "schema_version": {
      "const": "reporting-result-v1"
    },
    "incident_id": {
      "type": "string"
    },
    "alert_id": {
      "type": "string"
    },
    "report_status": {
      "type": "string"
    },
    "generated_reports": {
      "type": "object"
    }
  }
}